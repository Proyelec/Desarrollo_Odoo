<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_list_procura_kpi" model="ir.ui.view">
        <field name="name">project.task.list.procura.kpi</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.project_task_view_tree_main_base"/>
        <field name="arch" type="xml">
            <field name="date_last_stage_update" position="after">
                <field name="x_kpi_efectividad"
                       string="KPI Efectividad (%)"
                       optional="show"
                       widget="progressbar"
                       options="{'max_value': 100, 'editable': false}"/>
            </field>
        </field>
    </record>

    <record id="view_task_kanban_procura_kpi" model="ir.ui.view">
        <field name="name">project.task.kanban.procura.kpi</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <field name="project_id" position="after">
                <field name="x_kpi_efectividad"/>
            </field>
            <xpath expr="//div[hasclass('oe_kanban_bottom_right')]" position="inside">
                <t t-if="record.x_kpi_efectividad.raw_value > 0">
                    <span class="badge rounded-pill text-bg-success ms-1"
                          title="KPI Efectividad: Renglones Ganados / Ofertados">
                        <t t-esc="record.x_kpi_efectividad.value"/>%
                    </span>
                </t>
            </xpath>
        </field>
    </record>

    <record id="view_task_search_procura_kpi" model="ir.ui.view">
        <field name="name">project.task.search.procura.kpi</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_search_form"/>
        <field name="arch" type="xml">
            <filter name="my_tasks" position="before">
                <filter string="Con Renglones (PROCURA)"
                        name="con_renglones_procura"
                        domain="[('project_id', '=', 1019), ('x_kpi_efectividad', '>', 0)]"/>
                <separator/>
            </filter>
        </field>
    </record>

</odoo>