<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_so_to_po" model="ir.ui.view">
        <field name="name">sale.order.form.so_to_po</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" icon="fa-list">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="x_kpi_ganado_lines"/>/<field name="x_kpi_total_lines"/>
                        </span>
                        <span class="o_stat_text">Ganado</span>
                    </div>
                </button>
                <button class="oe_stat_button" icon="fa-percent">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="x_kpi_conversion_rate"/>%
                        </span>
                        <span class="o_stat_text">Conversión</span>
                    </div>
                </button>
            </xpath>

            <xpath expr="//field[@name='order_line']/tree//field[@name='price_unit']" position="after">
                <field name="x_studio_ganado" optional="show"/>
            </xpath>

        </field>
    </record>
</odoo>