<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_so_to_po_wizard_form" model="ir.ui.view">
        <field name="name">proyelec.so.to.po.wizard.form</field>
        <field name="model">proyelec.so.to.po.wizard</field>
        <field name="arch" type="xml">
            <form string="Transferir líneas Ganado a OC">
                <group>
                    <field name="sale_order_id" readonly="1"/>
                    <field name="partner_id"/>
                </group>
                <field name="line_ids">
                    <tree editable="bottom">
                        <field name="selected"/>
                        <field name="product_id"/>
                        <field name="product_qty"/>
                        <field name="price_unit"/>
                        <field name="sale_line_id" column_invisible="1"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_create_po" string="Crear / Actualizar OC" type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
