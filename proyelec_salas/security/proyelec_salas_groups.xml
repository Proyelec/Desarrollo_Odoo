<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_room_booking" model="ir.module.category">
            <field name="name">Salas de Reunión Proyelec</field>
            <field name="sequence">50</field>
        </record>

        <record id="group_room_booking_user" model="res.groups">
            <field name="name">Usuario</field>
            <field name="category_id" ref="module_category_room_booking"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_room_booking_leader" model="res.groups">
            <field name="name">Líder / Gerencia</field>
            <field name="category_id" ref="module_category_room_booking"/>
            <field name="implied_ids" eval="[(4, ref('group_room_booking_user'))]"/>
        </record>
    </data>
</odoo>
